{
  "name": "oduaildr/liberty-cmd-package",
  "description": "DebtPlete CMD and SQL reports module",
  "type": "library",
  "require": {
    "php": "^8.3 || ^8.4",
    "firebase/php-jwt": "^6.0 || ^7.0",
    "guzzlehttp/guzzle": "^7.10",
    "phpoffice/phpspreadsheet": "^1.29",
    "phpseclib/phpseclib": "^3.0",
    "ext-sqlsrv": "*",
    "ext-pdo_sqlsrv": "*"
  },
  "require-dev": {
    "illuminate/support": "^11.0 || ^12.0",
    "phpunit/phpunit": "^11.5",
    "ramsey/uuid": "^4.7"
  },
  "autoload": {
    "psr-4": {
      "Cmd\\Reports\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Cmd\\Reports\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Cmd\\Reports\\ReportsServiceProvider"
      ]
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit"
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
